# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only (Netlify env for functions). Must be the "service_role" key from Dashboard → Settings → API — not the anon key. Used for order email, webhooks, admin writes; bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Vendor app URL (vendor order notification emails link here, e.g. /orders)
VENDOR_PORTAL_URL=https://vendors.julinemart.com

# WooCommerce
WOOCOMMERCE_URL=https://your-woocommerce-site.com/wp-json/wc/v3
WOOCOMMERCE_CONSUMER_KEY=your_woocommerce_consumer_key
WOOCOMMERCE_CONSUMER_SECRET=your_woocommerce_consumer_secret
WEBHOOK_SECRET=your_webhook_secre

# Courier APIs
FEZ_API_KEY=your_fez_api_key
FEZ_PASSWORD=your_fez_api_key
FEZ_USER_ID=your_fez_user_id
FEZ_API_BASE_URL=https://api.fezdelivery.co/api/v1
FEZ_API_URL=https://api.fezdelivery.co/api/v1
GIGL_API_KEY=your_gigl_api_key
GIGL_API_URL=https://api.gigl.com

# Paystack
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# App Settings
NODE_ENV=development
API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=
VITE_APP_NAME=JulineMart
VITE_LOGO_URL=https://res.cloudinary.com/dupgdbwrt/image/upload/v1759971092/icon-512x512.png_ygtda9.png

# Global Sourcing FX
EXCHANGERATE_API_KEY=your_exchangerate_host_api_key
EXCHANGERATE_API_BASE_URL=https://api.exchangerate.host
FX_RATE_CACHE_MINUTES=60

# ========================================
# EMAIL CONFIGURATION
# ========================================

# Email Provider: gmail | sendgrid | smtp
EMAIL_PROVIDER=gmail

# Gmail Configuration (for testing)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=JulineMart <your-email@gmail.com>

# SendGrid Configuration (recommended for production)
# SENDGRID_API_KEY=your_sendgrid_api_key

# Custom SMTP Configuration
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_user
# SMTP_PASSWORD=your_smtp_password

# Customer Portal URL (for tracking links in emails)
CUSTOMER_PORTAL_URL=http://localhost:3002

# Email Testing
# Set to 'true' to enable email sending
EMAIL_ENABLED=true

# Supabase Database Webhook → POST /api/notify-order-confirmation (Bearer token)
# Generate a long random string; set the same value in Supabase webhook Authorization header.
ORDER_EMAIL_WEBHOOK_SECRET=

# ========================================
# PUSH NOTIFICATIONS (JLO ADMIN PROXY)
# ========================================
# Base URL of your PWA project/server (no trailing slash required)
# Local:      http://localhost:3000
# Preview:    https://dev-lab--julinemart-pwa.netlify.app
# Production: https://julinemart.com
PWA_BASE_URL=https://dev-lab--julinemart-pwa.netlify.app
# or production:
# PWA_BASE_URL=https://julinemart.com
# or local PWA port if running locally (not 8888), e.g.:
# PWA_BASE_URL=http://localhost:3002

# Server-only secret required by PWA for bulk notification audiences
NOTIFICATIONS_ADMIN_SECRET=your_notifications_admin_secret
